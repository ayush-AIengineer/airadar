# ── AIRadar environment ─────────────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored. Never commit real secrets.

# Environment: local | staging | prod
AIRADAR_ENV=local

# ── Database ─────────────────────────────────────────────────────────────────
# Phase 1 default: local SQLite (async driver). Swap to Postgres in Phase 2:
#   AIRADAR_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/airadar
AIRADAR_DATABASE_URL=sqlite+aiosqlite:///./airadar.db

# ── LLM (Enrichment / Discovery classifier) ──────────────────────────────────
# Required once the enrichment stage runs. Leave blank for scaffold/DB work.
AIRADAR_ANTHROPIC_API_KEY=
AIRADAR_ENRICHMENT_MODEL=claude-sonnet-4-6
AIRADAR_CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# Embeddings for semantic dedup. Blank → offline hashing embedder (no cost).
AIRADAR_OPENAI_API_KEY=

# ── Dedup / Curator ───────────────────────────────────────────────────────────
AIRADAR_QDRANT_PATH=./qdrant_data
AIRADAR_DEDUP_SIMILARITY_THRESHOLD=0.88
AIRADAR_DEDUP_LOOKBACK_DAYS=90

# ── Pipeline tuning (mirrors Architecture §11 cost discipline) ────────────────
AIRADAR_DISCOVERY_SIGNAL_THRESHOLD=0.6
AIRADAR_MAX_ENRICHMENT_PER_DAY=300
AIRADAR_MIN_WORD_COUNT=100

# ── Source API keys (added as adapters land) ──────────────────────────────────
AIRADAR_PRODUCTHUNT_TOKEN=
AIRADAR_GITHUB_TOKEN=
# Hacker News (Algolia) needs no key.
